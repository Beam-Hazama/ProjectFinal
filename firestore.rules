rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if user is authenticated (Note: Currently not in use as Firebase Auth is missing)
    function isAuthenticated() {
      return request.auth != null;
    }

    // User Collection: 
    // CRITICAL - Current login system requires public read to find users by username.
    // Recommended: Implement Firebase Authentication and restrict this.
    match /User/{userId} {
      allow read: if true; 
      allow create: if true; 
      allow update, delete: if false; 
    }

    // Restaurant Data: Publicly readable for browsing.
    match /Restaurant/{id} { allow read: if true; allow write: if true; }
    match /Menu/{id} { allow read: if true; allow write: if true; }
    match /Poster/{id} { allow read: if true; allow write: if true; }
    match /Category/{id} { allow read: if true; allow write: if true; }
    match /Commission/{id} { allow read: if true; allow write: if true; }

    // Orders: Anyone can create/update (required for status flow), but none can delete.
    match /Order/{id} {
      allow read, create, update: if true;
      allow delete: if false;
    }
  }
}