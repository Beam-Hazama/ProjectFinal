rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/User/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/User/$(request.auth.uid)).data.Role == 'admin';
    }

    match /User/{userId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /Restaurant/{id} { allow read: if true; allow write: if isAdmin(); }
    match /Menu/{id} { 
      allow read: if true; 
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ✅ เพิ่ม posters (ตัวเล็ก) ที่โค้ดใช้จริง
    match /posters/{id} { allow read: if true; allow write: if isAdmin(); }
    match /Poster/{id} { allow read: if true; allow write: if isAdmin(); }

    // ✅ categories ตัวเล็ก ที่โค้ดใช้จริง  
    match /categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /Category/{id} { allow read: if true; allow write: if isAdmin(); }

    match /Commission/{id} { allow read: if true; allow write: if isAdmin(); }
    match /QRCodes/{id} { allow read: if true; allow write: if isAdmin(); }

    match /Order/{id} {
      allow read, create, update: if true;
      allow delete: if false;
    }
  }
}